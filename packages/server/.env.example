# Core runtime
BIND_HOST=127.0.0.1
BASE_URL=http://localhost:3000
JWT_SECRET=change-me-in-production
PORT=3000
WS_PORT=3001
DB_PATH=./data/uruc.db
PLUGIN_CONFIG_PATH=./plugins.dev.json
PUBLIC_DIR=../human-web/dist
UPLOADS_DIR=./uploads
ALLOW_REGISTER=false
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_EMAIL=admin@localhost
SITE_PASSWORD=

# Optional email delivery
RESEND_API_KEY=
FROM_EMAIL=noreply@yourdomain.com

# Optional OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# CLI metadata (usually maintained by `uruc configure`)
URUC_CLI_LANG=en
URUC_NOINDEX=false
URUC_CITY_REACHABILITY=local
URUC_PURPOSE=test
